#include<iostream>
using namespace std;
//function for finding the factorial of given number.
int fact(int a) {
	int fact1 = 1;
	for (int x = 1;x <= a;x++) {
		fact1 = fact1 * x;
	}
	return  fact1;
}
//main functio from we call the previous function.
int main() {
	int num{};
	cout << "Enter a number: ";
	cin >> num;
	//call the factorial function.
	cout << "The factorial given function is: " << fact(num) << endl;
	return 0;
};

