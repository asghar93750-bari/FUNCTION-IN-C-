#include <iostream>
using namespace std;
//function for finding sum of two number.
int add(int a, int b) {
	return a + b;
}
int main() {

	int num1{}, num2{};
	cout << "Enter two numbers: ";
	cin >> num1 >> num2;
	//call the function for finding the sum of number.
	cout << "the sum of two number: " << add(num1, num2);

};
